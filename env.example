POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=jobeco
POSTGRES_USER=jobeco
POSTGRES_PASSWORD=jobeco

# SQLAlchemy URL for apps (async driver)
DATABASE_URL=postgresql+asyncpg://jobeco:jobeco@postgres:5432/jobeco

# Telegram
ADMIN_BOT_TOKEN=CHANGE_ME
ADMIN_IDS=123456789

TELETHON_API_ID=0
TELETHON_API_HASH=CHANGE_ME
TELETHON_SESSION_PATH=/data/telethon/userbot.session

# OpenRouter
OPENROUTER_API_KEY=CHANGE_ME
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL_CLASSIFIER=gpt-4o-mini
OPENROUTER_MODEL_ANALYZER=gpt-4o

# Embeddings
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536
DEDUP_THRESHOLD=0.95

